{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://verity.invalid/schemas/phase0/verdict.schema.json",
  "title": "Validated verdict fixture",
  "type": "object",
  "required": ["schema_version", "fixture_status", "measured", "verdict"],
  "properties": {
    "schema_version": {"const": 1},
    "fixture_status": {"enum": ["placeholder_not_measured", "reviewed_disclosed_fixture"]},
    "measured": {"type": "boolean"},
    "verdict": {"type": ["object", "null"]}
  },
  "additionalProperties": true
}
