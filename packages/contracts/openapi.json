{
  "components": {
    "schemas": {
      "Claim": {
        "properties": {
          "classification": {
            "$ref": "#/components/schemas/Classification"
          },
          "completed_at": {
            "anyOf": [
              {
                "format": "date-time",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Completed At"
          },
          "created_at": {
            "format": "date-time",
            "title": "Created At",
            "type": "string"
          },
          "end_ms": {
            "minimum": 0.0,
            "title": "End Ms",
            "type": "integer"
          },
          "evidence": {
            "items": {
              "$ref": "#/components/schemas/Evidence"
            },
            "title": "Evidence",
            "type": "array"
          },
          "exact_text": {
            "minLength": 1,
            "title": "Exact Text",
            "type": "string"
          },
          "fixture_mode": {
            "default": true,
            "title": "Fixture Mode",
            "type": "boolean"
          },
          "normalized_text": {
            "minLength": 1,
            "title": "Normalized Text",
            "type": "string"
          },
          "public_id": {
            "title": "Public Id",
            "type": "string"
          },
          "session_id": {
            "title": "Session Id",
            "type": "string"
          },
          "speaker_label": {
            "title": "Speaker Label",
            "type": "string"
          },
          "start_ms": {
            "minimum": 0.0,
            "title": "Start Ms",
            "type": "integer"
          },
          "state": {
            "$ref": "#/components/schemas/ClaimState"
          },
          "verdict": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/Verdict"
              },
              {
                "type": "null"
              }
            ]
          }
        },
        "required": [
          "public_id",
          "session_id",
          "speaker_label",
          "exact_text",
          "normalized_text",
          "start_ms",
          "end_ms",
          "classification",
          "state",
          "created_at"
        ],
        "title": "Claim",
        "type": "object"
      },
      "ClaimState": {
        "enum": [
          "CAPTURING",
          "TRANSCRIBING",
          "CLAIM_CANDIDATE",
          "CHECKING",
          "EVIDENCE_READY",
          "SYNTHESIZING",
          "COMPLETE",
          "INSUFFICIENT_EVIDENCE",
          "FAILED"
        ],
        "title": "ClaimState",
        "type": "string"
      },
      "Classification": {
        "enum": [
          "opinion",
          "factual_claim",
          "unverifiable"
        ],
        "title": "Classification",
        "type": "string"
      },
      "Evidence": {
        "properties": {
          "canonical_url": {
            "format": "uri",
            "maxLength": 2083,
            "minLength": 1,
            "title": "Canonical Url",
            "type": "string"
          },
          "content_hash": {
            "title": "Content Hash",
            "type": "string"
          },
          "excerpt": {
            "title": "Excerpt",
            "type": "string"
          },
          "id": {
            "title": "Id",
            "type": "string"
          },
          "published_at": {
            "format": "date-time",
            "title": "Published At",
            "type": "string"
          },
          "publisher": {
            "title": "Publisher",
            "type": "string"
          },
          "retrieved_at": {
            "format": "date-time",
            "title": "Retrieved At",
            "type": "string"
          },
          "source_tier": {
            "$ref": "#/components/schemas/SourceTier"
          },
          "stance": {
            "$ref": "#/components/schemas/Stance"
          },
          "title": {
            "title": "Title",
            "type": "string"
          }
        },
        "required": [
          "id",
          "stance",
          "title",
          "canonical_url",
          "publisher",
          "published_at",
          "retrieved_at",
          "excerpt",
          "source_tier",
          "content_hash"
        ],
        "title": "Evidence",
        "type": "object"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "Pairing": {
        "properties": {
          "code": {
            "default": "123456",
            "title": "Code",
            "type": "string"
          },
          "expires_at": {
            "format": "date-time",
            "title": "Expires At",
            "type": "string"
          }
        },
        "required": [
          "expires_at"
        ],
        "title": "Pairing",
        "type": "object"
      },
      "PushSubscription": {
        "properties": {
          "device_id": {
            "title": "Device Id",
            "type": "string"
          },
          "endpoint": {
            "default": "fake://local",
            "title": "Endpoint",
            "type": "string"
          }
        },
        "required": [
          "device_id"
        ],
        "title": "PushSubscription",
        "type": "object"
      },
      "SessionCreate": {
        "properties": {
          "idempotency_key": {
            "maxLength": 128,
            "minLength": 1,
            "title": "Idempotency Key",
            "type": "string"
          },
          "video_title": {
            "default": "Hero demo",
            "title": "Video Title",
            "type": "string"
          },
          "video_url": {
            "default": "https://youtube.com/watch?v=hero",
            "title": "Video Url",
            "type": "string"
          }
        },
        "required": [
          "idempotency_key"
        ],
        "title": "SessionCreate",
        "type": "object"
      },
      "SessionCreated": {
        "properties": {
          "credential": {
            "title": "Credential",
            "type": "string"
          },
          "fixture_mode": {
            "default": true,
            "title": "Fixture Mode",
            "type": "boolean"
          },
          "id": {
            "title": "Id",
            "type": "string"
          }
        },
        "required": [
          "id",
          "credential"
        ],
        "title": "SessionCreated",
        "type": "object"
      },
      "SourceTier": {
        "enum": [
          "primary",
          "research",
          "established"
        ],
        "title": "SourceTier",
        "type": "string"
      },
      "Stance": {
        "enum": [
          "support",
          "counter",
          "context"
        ],
        "title": "Stance",
        "type": "string"
      },
      "ValidationError": {
        "properties": {
          "ctx": {
            "title": "Context",
            "type": "object"
          },
          "input": {
            "title": "Input"
          },
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      },
      "Verdict": {
        "properties": {
          "citation_ids": {
            "items": {
              "type": "string"
            },
            "title": "Citation Ids",
            "type": "array"
          },
          "common_ground": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Common Ground"
          },
          "confidence": {
            "maximum": 1.0,
            "minimum": 0.0,
            "title": "Confidence",
            "type": "number"
          },
          "counterevidence_summary": {
            "title": "Counterevidence Summary",
            "type": "string"
          },
          "explanation": {
            "title": "Explanation",
            "type": "string"
          },
          "label": {
            "$ref": "#/components/schemas/VerdictLabel"
          },
          "model_name": {
            "default": "hero-fixture",
            "title": "Model Name",
            "type": "string"
          },
          "model_provider": {
            "default": "fake",
            "title": "Model Provider",
            "type": "string"
          },
          "prompt_version": {
            "default": "phase1",
            "title": "Prompt Version",
            "type": "string"
          },
          "uncertainty": {
            "title": "Uncertainty",
            "type": "string"
          }
        },
        "required": [
          "label",
          "confidence",
          "explanation",
          "uncertainty",
          "counterevidence_summary",
          "citation_ids"
        ],
        "title": "Verdict",
        "type": "object"
      },
      "VerdictLabel": {
        "enum": [
          "Supported",
          "Misleading",
          "Disputed",
          "Unsupported",
          "Insufficient evidence"
        ],
        "title": "VerdictLabel",
        "type": "string"
      }
    }
  },
  "info": {
    "title": "Verity API",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
